\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Forward Mapping (SSP $\rightarrow $ GTSP). A single configuration $C_1$ covering three jobs is duplicated into mutually exclusive replicas connected by zero-cost edges, establishing a bijective mapping to the optimal SSP tool retention logic.}}{9}{figure.caption.3}\protected@file@percent }
\newlabel{fig:forward_mapping}{{3}{9}{Forward Mapping (SSP $\rightarrow $ GTSP). A single configuration $C_1$ covering three jobs is duplicated into mutually exclusive replicas connected by zero-cost edges, establishing a bijective mapping to the optimal SSP tool retention logic}{figure.caption.3}{}}
